{
  "name": "h2ui-cli",
  "version": "1.1.2",
  "description": "Convert HTML pages to React/Vue components with batch processing, component splitting, and live preview server",
  "type": "module",
  "main": "./dist/src/cli/index.js",
  "bin": {
    "h2ui": "./dist/bin/h2ui.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "test-schema": "tsx verify-work/test_schema.ts",
    "convert-test": "tsx src/cli/index.ts convert verify-work/dashboard.html --out verify-work/output"
  },
  "keywords": [
    "html",
    "react",
    "vue",
    "vue3",
    "jsx",
    "tsx",
    "converter",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "cheerio": "^1.2.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.1",
    "css-tree": "^3.2.1",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/css-tree": "^2.3.11",
    "@types/node": "^25.9.1",
    "@types/ora": "^3.1.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
